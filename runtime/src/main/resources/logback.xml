<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Appender to log to console -->
    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSS,UTC}Z ${LOG_LEVEL_PATTERN:-%5p} %m%n</pattern>
            <charset>utf8</charset>
        </encoder>
    </appender>

    <logger name="io.qalipsis" level="INFO" additivity="false">
        <appender-ref ref="console"/>
    </logger>

    <root level="WARN">
        <appender-ref ref="console"/>
    </root>

    <include optional="true" resource="qalipsis-logback.xml"/>
    <include optional="true" file="qalipsis-logback.xml"/>
    <include optional="true" resource="config/qalipsis-logback.xml"/>
    <include optional="true" file="config/qalipsis-logback.xml"/>
</configuration>
